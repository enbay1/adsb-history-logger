[Unit]
Description=Local ADS-B position history logger
After=network.target dump1090-fa.service

[Service]
Type=simple
User=adsb-history-logger
Group=adsb-history-logger
StateDirectory=adsb-history-logger
EnvironmentFile=-/etc/default/adsb-history-logger
ExecStart=/usr/bin/adsb-history-logger
Restart=on-failure
RestartSec=5
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
